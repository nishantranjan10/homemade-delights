PORT=5050
MONGO_URI=mongodb://127.0.0.1:27017/rupalis_delights
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
# Set to "production" to disable the dev verification-code fallback
NODE_ENV=development

# Default admin account created by the seed script
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
# Where admin verification codes are sent (for changing username/password)
ADMIN_EMAIL=
ADMIN_PHONE=+6583136991

# --- Email delivery (optional) -------------------------------------------
# If SMTP_HOST is unset, codes are logged to the server console instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Rupali's Homemade Delights <no-reply@rupalis.sg>"

# --- WhatsApp delivery via Twilio (optional) ------------------------------
# If these are unset, codes are logged to the server console instead.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
